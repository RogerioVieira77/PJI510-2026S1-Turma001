# =============================================================================
# PiscinãoMonitor — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA faça commit do arquivo .env
# =============================================================================

# --- Banco de Dados PostgreSQL + TimescaleDB ---
POSTGRES_USER=piscinao
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=piscinao_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL completa para SQLAlchemy Async (preenchida automaticamente pelo compose)
DATABASE_URL=postgresql+asyncpg://piscinao:TROQUE_POR_SENHA_FORTE@postgres:5432/piscinao_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=TROQUE_POR_SENHA_FORTE_REDIS

REDIS_URL=redis://:TROQUE_POR_SENHA_FORTE_REDIS@redis:6379/0

# --- Segurança JWT ---
# Gere com: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=TROQUE_POR_STRING_ALEATORIA_DE_128_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Autenticação de Sensor (API Key) ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
INGESTAO_API_KEY=TROQUE_POR_API_KEY_SEGURA

# --- VAPID (Web Push Notifications) ---
# Gere com: python scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@piscinao.local

# --- Email / SMTP ---
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=alertas@piscinao.local
SMTP_PASSWORD=TROQUE_POR_SENHA_EMAIL
SMTP_FROM=PiscinãoMonitor <alertas@piscinao.local>
SMTP_TLS=true

# --- CORS ---
# Lista separada por vírgulas de origens permitidas
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# --- Backend ---
# Valores aceitos: development | homolog | production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# --- Integração Climática (EPIC-11) ---
OPENWEATHER_API_KEY=OBTENHA_EM_openweathermap.org

# =============================================================================
# BLOCO HOM — Preencha estas variáveis no servidor de homologação
# Substitua o bloco acima por estes valores ao criar o .env no servidor
# =============================================================================
# APP_ENV=homolog
# LOG_LEVEL=warning
# CORS_ORIGINS=https://vigia-romano.unicomunitaria.com.br
